# AWS Configuration for MixFade S3 Deployment
# Copy this file to .env and fill in your AWS credentials

# Required: Your AWS Access Key ID
# Get this from AWS IAM Console > Users > Your User > Security credentials
AWS_ACCESS_KEY_ID=your_access_key_here

# Required: Your AWS Secret Access Key
# Get this from AWS IAM Console when creating access keys
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Optional: AWS Region (defaults to us-east-1)
# Choose a region close to your users for faster downloads
AWS_REGION=us-east-1

# Optional: S3 Bucket Name (defaults to mixfade-releases)
# Must be globally unique across all AWS accounts
AWS_S3_BUCKET=mixfade-releases

# SECURITY WARNING:
# - Never commit the actual .env file to version control
# - Keep your AWS credentials secure and private
# - Consider using IAM users with limited S3 permissions instead of root credentials
# - Rotate your access keys regularly